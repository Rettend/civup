{
  "name": "@civup/game",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.7",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "tsgo --noEmit",
    "sync:bbg-live": "bun ./scripts/sync-bbg-leaders.ts live",
    "sync:bbg-beta": "bun ./scripts/sync-bbg-leaders.ts beta",
    "sync:bbg": "bun run sync:bbg-live && bun run sync:bbg-beta"
  },
  "dependencies": {
    "@civup/utils": "workspace:*"
  }
}
